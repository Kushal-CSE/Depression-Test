# Depression Test Platform - Environment Configuration
# Copy this file to .env.local and fill in your values

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# ML Prediction Service (Flask backend)
# Set to your Flask ML service URL for predictions (0,1,2,3)
NEXT_PUBLIC_ML_SERVICE_URL=http://localhost:5000

# Google OAuth (Optional)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here

# Feature Flags
NEXT_PUBLIC_ENABLE_GOOGLE_LOGIN=false
NEXT_PUBLIC_ENABLE_EMAIL_VERIFICATION=false
NEXT_PUBLIC_USE_ML_PREDICTIONS=true
